{
  "compilerOptions": {
    "allowSyntheticDefaultImports": true,
    "alwaysStrict": true,
    "esModuleInterop": true,
    "importHelpers": false,
    "noEmit": true,
    "noUncheckedIndexedAccess": true,
    "resolveJsonModule": true,
    "rootDir": ".",
    "types": ["bun"]
  },
  "exclude": ["test/fixtures"],
  "extends": "@tsconfig/bun/tsconfig.json",
  "include": ["*.config.ts", "scripts/**/*", "src/**/*", "test/**/*"]
}
